# ==============================
# HN-AI-Summarizer Configuration
# ==============================
#
# ÇALIŞTIRMA MODLARI:
#
# 1) Docker - internal servisler (PostgreSQL + Redis otomatik):
#      docker compose --profile internal up
#
# 2) Docker - external servisler (kendi PostgreSQL/Redis'inizi kullanın):
#      docker compose up
#      (db/redis servisleri profil ile kapatılır, .env'deki bağlantılar kullanılır)
#
# 3) Yerel geliştirme (Docker'sız):
#      pip install -r requirements.txt
#      DEVELOPMENT=true olarak ayarlayın → SQLite kullanır
#      Redis çalışıyor olmalı (localhost:6379)

# ==============================
# AI Provider API Keys
# ==============================
# NOT: API anahtarları SADECE .env dosyasından okunur.
#      Frontend tarafına ASLA gönderilmez.
#      Boş bırakılan sağlayıcılar settings sayfasında listelenmez.
#
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# LM Studio: Yerel çalışır, API anahtarı gerekmez
# Ollama: Yerel çalışır, API anahtarı gerekmez

# ==============================
# Database settings
# ==============================
# Internal servislerde (docker compose --profile internal up) bu değerler opsiyoneldir
# External modda (docker compose up) zorunludur
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hn_ai_summerizer_db

# ==============================
# Redis settings
# ==============================
# Internal: ayarlamaya gerek yok (redis://redis:6379/0)
# External/Docker'sız: aşağıdaki değerleri kendi Redis'inize göre ayarlayın
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ==============================
# Development mode
# ==============================
# true  → SQLite kullanır, PostgreSQL gerekmez (yerel geliştirme)
# false → PostgreSQL kullanır (Docker compose)
DEVELOPMENT=False

# Database echo (debugging - SQL queries gösterir)
DB_ECHO=False

# ==============================
# Optional Email Settings
# ==============================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=