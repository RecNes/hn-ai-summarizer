# ==============================
# HN-AI-Summarizer Configuration
# ==============================
#
# RUN MODES:
#
# 1) Docker with internal services (PostgreSQL + Redis auto-started):
#      docker compose --profile internal up
#
# 2) Docker with external services (use your own PostgreSQL/Redis):
#      docker compose up
#      (db/redis services are profile-disabled, uses .env connections)
#
# 3) Local development (no Docker):
#      pip install -e .
#      Set DEVELOPMENT=true → uses SQLite
#      Redis must be running (localhost:6379)

# ==============================
# Logging
# ==============================
# Log level for backend application logs (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Set to DEBUG for detailed troubleshooting in container logs
LOG_LEVEL=INFO

# ==============================
# AI Provider API Keys
# ==============================
# NOTE: API keys are read EXCLUSIVELY from .env.
#      They are NEVER sent to the frontend.
#      Providers left empty won't appear in the settings page.
#
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# LM Studio: Runs locally, no API key needed
# Ollama: Runs locally, no API key needed

# ==============================
# Database settings
# ==============================
# With internal services (docker compose --profile internal up) these values are optional
# In external mode (docker compose up) these are required
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hn_ai_summerizer_db

# ==============================
# Redis settings
# ==============================
# Internal: no configuration needed (redis://redis:6379/0)
# External/No Docker: adjust values to match your Redis setup
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ==============================
# Development mode
# ==============================
# true  → Uses SQLite, no PostgreSQL required (local development)
# false → Uses PostgreSQL (Docker compose)
DEVELOPMENT=False

# Database echo (debugging - shows SQL queries)
DB_ECHO=False

# ==============================
# Public URL Settings
# ==============================
# The public-facing URL of the application.
# Used in links within Telegram/email notifications.
# Set to your production domain (e.g., https://hnreader.example.com).
# Defaults to http://localhost:8000 for development.
PUBLIC_URL=http://localhost:8000

# ==============================
# Telegram Settings
# ==============================
# Telegram bot token for sending notifications about new stories.
# Create a bot via @BotFather on Telegram and paste the token here.
# Telegram chat ID is configured via the web interface settings page.
TELEGRAM_BOT_TOKEN=

# ==============================
# Optional Email Settings
# ==============================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=