[MASTER]
ignore=migrations,tests

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    C0103,  # invalid-name
    C0301,  # line-too-long (handled by flake8/black)
    C0303,  # trailing-whitespace (handled by black)
    C0304,  # missing-final-newline (handled by black)
    R0903,  # too-few-public-methods (ORM models)
    R1705,  # no-else-return (personal style)
    C0121,  # singleton-comparison (== False is clearer sometimes)
    W0107,  # unnecessary-pass (schema classes with Config)
    R1732,  # consider-using-with (subprocess patterns)
    W0718,  # broad-exception-caught (intentional top-level handlers)
    W0611,  # unused-import (handled by flake8)
    W0707,  # raise-missing-from (style preference)
    W1203,  # logging-fstring-interpolation
    W1309,  # f-string-without-interpolation
    C0415,  # import-outside-toplevel (lazy imports OK)
    R0914,  # too-many-locals
    R0915,  # too-many-statements
    R0912,  # too-many-branches
    R0911,  # too-many-return-statements
    R0913,  # too-many-arguments
    R0917,  # too-many-positional-arguments
    R0801,  # duplicate-code
    R0401,  # cyclic-import
    W0404,  # reimported
    W0621,  # redefined-outer-name
    W0640,  # cell-var-from-loop
    W0613,  # unused-argument
    E1136,  # unsubscriptable-object (SQLAlchemy 2.0 Mapped type false positive)

[FORMAT]
max-line-length=120

[BASIC]
good-names=
    i,
    j,
    k,
    ex,
    Run,
    _,
    db,
    id,
    ok,
    r,
    ctx,
    fn,

[DESIGN]
max-parents=13
max-attributes=15
min-public-methods=0
max-public-methods=20
